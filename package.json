{
  "name": "showme-redesign",
  "version": "1.0.0",
  "description": "A screen-aware visual lesson compiler for Windows and macOS.",
  "main": "./out/main/index.js",
  "author": "ShowME contributors",
  "license": "Apache-2.0",
  "type": "module",
  "scripts": {
    "dev": "electron-vite dev",
    "dev:web": "vite --config vite.web.config.ts",
    "preview": "electron-vite preview",
    "build": "npm run typecheck && electron-vite build",
    "typecheck": "tsc --noEmit -p tsconfig.node.json && tsc --noEmit -p tsconfig.web.json",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:rust": "cargo test --manifest-path workers/native/Cargo.toml",
    "test:python": "python -m unittest discover -s workers/python/tests -p \"test_*.py\"",
    "test:wake": "node scripts/test-wake.mjs",
    "build:rust": "cargo build --release --manifest-path workers/native/Cargo.toml",
    "build:python": "python scripts/build-python-worker.py",
    "build:icons": "node scripts/build-icons.mjs",
    "build:workers": "npm run build:rust && npm run build:python",
    "check": "npm run format:check && npm run lint && npm run typecheck && npm run test && npm run test:wake && npm run test:rust && npm run test:python",
    "pack": "npm run check && npm run build:workers && npm run build:icons && npm run build && electron-builder --dir",
    "package:win": "npm run check && npm run build:workers && npm run build:icons && npm run build && electron-builder --win nsis portable",
    "postinstall": "electron-builder install-app-deps"
  },
  "dependencies": {
    "lucide-react": "^1.25.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "simple-icons": "^16.27.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^24.13.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.4",
    "electron": "43.1.1",
    "electron-builder": "26.15.3",
    "electron-vite": "5.0.0",
    "jsdom": "^29.1.1",
    "png-to-ico": "^3.0.1",
    "sharp": "^0.34.5",
    "typescript": "^7.0.2",
    "vite": "^7.3.1",
    "vitest": "^4.1.10"
  }
}
