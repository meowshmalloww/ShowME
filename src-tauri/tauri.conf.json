{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ShowME",
  "version": "0.2.0",
  "identifier": "com.showme.visual",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [],
    "security": {
      "capabilities": ["desktop"],
      "csp": {
        "default-src": "'self'",
        "connect-src": "'self' ipc: http://ipc.localhost",
        "font-src": "'self' data:",
        "frame-src": "'self'",
        "img-src": "'self' asset: http://asset.localhost data: blob: https://upload.wikimedia.org",
        "media-src": "'self' data: blob:",
        "object-src": "'none'",
        "script-src": "'self'",
        "style-src": "'self' 'unsafe-inline'",
        "base-uri": "'none'",
        "frame-ancestors": "'none'"
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "Education",
    "shortDescription": "Turn confusing screen content into interactive visual lessons.",
    "longDescription": "ShowME is a voice-first, screen-aware visual lesson compiler for Windows and macOS.",
    "copyright": "Copyright 2026 ShowME contributors",
    "icon": ["icons/icon.ico"],
    "windows": {
      "webviewInstallMode": {
        "type": "downloadBootstrapper",
        "silent": true
      }
    },
    "macOS": {
      "minimumSystemVersion": "12.3"
    }
  }
}
